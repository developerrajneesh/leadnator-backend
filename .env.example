# Server
PORT=8080
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=
# Dev only — fallback if HTTPS still fails without `npm run dev` (uses node --use-system-ca)
# TLS_INSECURE=true
# MONGO_TLS_INSECURE=true
# Optional: comma-separated DNS (e.g. 1.1.1.1,8.8.8.8) when SRV lookups fail
# DNS_SERVERS=

# Auth
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mail (nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app_password
MAIL_FROM=Leadnator <no-reply@leadnator.app>

# Meta (Facebook) Ads — optional
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_API_VERSION=v23.0

# Meta Graph API base (rarely changes)
FB_APP_ID=
FB_APP_SECRET=

# WhatsApp Embedded Signup — get this from Meta Business Settings → WhatsApp →
# Embedded Signup configuration. Required for the in-app "Login with Facebook"
# WhatsApp signup button to work.
WHATSAPP_FB_CONFIG_ID=
# Optional overrides (if you want a separate FB app for WhatsApp than for Meta Ads):
WHATSAPP_FB_APP_ID=
WHATSAPP_FB_APP_SECRET=
# Only set if your FB app uses a redirect URI (most embedded signup flows don't)
WHATSAPP_OAUTH_REDIRECT_URI=

# Instagram Business Login (OAuth button in app)
INSTAGRAM_CLIENT_ID=1973429443277994
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://leadnator.vercel.app/
